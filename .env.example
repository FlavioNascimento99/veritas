# ============================================================
# DEVELOPMENT ENVIRONMENT VARIABLES (.env)
# ============================================================
# Copy this file to .env and adjust values as needed
# This file is used by docker-compose.yml
#
# DO NOT commit .env to git (keep only .env.example)
# ============================================================

# ========================================
# Spring Boot Configuration
# ========================================
# Profile: dev (uses application-dev.yml)
# Profiles: dev, prod
SPRING_PROFILES_ACTIVE=dev

# ========================================
# PostgreSQL Local Development Database
# ========================================
# Database user (non-root for security)
PGUSER=dev_user

# Database password (development only - not secure!)
PGPASSWORD=dev_password

# Database name
PGDATABASE=veritas_dev

# Host (service name in docker-compose)
PGHOST=postgres-local

# Port (standard PostgreSQL port)
PGPORT=5432

# ========================================
# JVM Configuration (Optional)
# ========================================
# Uncomment below to customize Java heap memory
# JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC
